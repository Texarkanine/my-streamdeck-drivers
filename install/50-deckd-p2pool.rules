// Polkit: allow a normal user to start/stop only p2pool.service (no password prompt).
// Install: sudo cp install/50-deckd-p2pool.rules /etc/polkit-1/rules.d/
//          sudo systemctl restart polkit
//
// Edit the username below to match the account that runs deckd (e.g. homeserv).

polkit.addRule(function (action, subject) {
    if (action.id !== "org.freedesktop.systemd1.manage-units") {
        return undefined;
    }
    if (subject.user !== "homeserv") {
        return undefined;
    }
    // Detail key is provided by systemd’s polkit integration (see pkaction --verbose).
    var unit = action.lookup("unit");
    if (unit === "p2pool.service") {
        return polkit.Result.YES;
    }
    return undefined;
});
