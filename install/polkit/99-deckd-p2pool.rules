// Polkit: allow deckd's Unix user to call systemd StartUnit/StopUnit over D-Bus without a password.
//
// Install:
//   sudo cp install/99-deckd-p2pool.rules /etc/polkit-1/rules.d/
//   sudo systemctl restart polkit
//
// IMPORTANT: Edit subject.user to match the account that runs deckd (e.g. deckd).
//
// Why not filter by unit? systemd does not always pass action.lookup("unit") to polkit in a way
// that matches a string compare, so unit-specific rules often never return YES and auth still fails.
// This rule allows manage-units for that user for ANY unit — narrower control is better done with
// sudoers + deckd.toml use_sudo_for_systemctl = true (see README and install/sudoers-deckd-p2pool.example).

polkit.addRule(function (action, subject) {
    if (action.id != "org.freedesktop.systemd1.manage-units") {
        return undefined;
    }
    if (subject.user != "deckd") {
        return undefined;
    }
    return polkit.Result.YES;
});
