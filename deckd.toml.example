[general]
# Embedded HTTP listener for OnAir sign registration (binds 0.0.0.0)
listen_port = 5111

[p2pool]
unit = "p2pool.service"
# Blink between these two PNGs while systemd reports ActiveState "deactivating"
deactivating_image_a = "monero_deactivating_a.png"
deactivating_image_b = "monero_deactivating_b.png"
# Seconds between A/B swaps (2 FPS = 0.5)
deactivating_blink_interval_sec = 0.5
# Optional: extra presses while "deactivating" call systemd KillUnit with this signal (e.g. 9 = SIGKILL, 15 = SIGTERM).
# Omit this key for no escalation — repeats do nothing until the unit reaches inactive/active.

[onair]
# Base URL of the OnAir server (no trailing slash)
server = "http://127.0.0.1:1920"
# Seconds between re-register POSTs (0 = register once at startup)
register_interval = 60

[images]
# Directory with monero_online.png, monero_offline.png, onair_on.png, onair_off.png
dir = "/opt/deckd/images"
